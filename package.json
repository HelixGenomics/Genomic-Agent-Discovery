{
  "name": "genomic-agent-discovery",
  "version": "1.0.0",
  "description": "AI agents that collaborate to analyze your DNA. 18 MCP tools, 12 databases, real-time dashboard. Runs locally.",
  "type": "module",
  "main": "src/cli.mjs",
  "bin": {
    "helix-agents": "src/cli.mjs"
  },
  "scripts": {
    "start": "node src/cli.mjs",
    "build-db": "bash scripts/build-database.sh",
    "seed-demo": "node scripts/seed-demo-data.mjs",
    "verify-db": "node scripts/verify-database.mjs",
    "test": "node --test 'tests/*.mjs'"
  },
  "keywords": [
    "genomics",
    "dna",
    "mcp",
    "ai-agents",
    "claude",
    "pharmacogenomics",
    "health",
    "bioinformatics",
    "model-context-protocol"
  ],
  "author": "Helix Sequencing <admin@helixsequencing.com>",
  "license": "MIT",
  "homepage": "https://github.com/HelixGenomics/Genomic-Agent-Discovery",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelixGenomics/Genomic-Agent-Discovery.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  }
}
