# ============================================================
# Genomic Agent Discovery — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values for your provider.
# You only need ONE provider configured.

# ============================================================
# OPTION 1: Claude CLI with subscription (RECOMMENDED)
# ============================================================
# No API key needed! Uses your Claude Max ($100/mo) or Pro ($20/mo) plan.
# One-time setup: run "claude login" in your terminal to authenticate.
# This is the cheapest and easiest option — your subscription covers
# unlimited agent runs with full MCP tool support.
#
# Set provider in config or CLI:
#   node src/cli.mjs --dna my-file.txt --provider claude-cli
#
# Nothing to set here — authentication is handled by the Claude CLI.

# ============================================================
# OPTION 2: Anthropic API Key (pay-per-use)
# ============================================================
# Get your key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ============================================================
# OPTION 3: OpenAI API Key (GPT-4o, GPT-4, o1)
# ============================================================
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# ============================================================
# OPTION 4: Google Gemini API Key
# ============================================================
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-key-here

# ============================================================
# OPTION 5: OpenAI-Compatible API (Groq, Together, Mistral, etc.)
# ============================================================
# OPENAI_COMPATIBLE_API_KEY=your-key-here
# OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1

# ============================================================
# OPTION 6: Ollama (FREE — runs locally)
# ============================================================
# Install Ollama: https://ollama.ai
# Pull a model: ollama pull llama3.1
# No key needed — just make sure Ollama is running.
# OLLAMA_URL=http://localhost:11434

# ============================================================
# General Settings
# ============================================================

# Override default model for all agents
# HELIX_DEFAULT_MODEL=sonnet

# Cost limit in USD (kills agents if exceeded) — API providers only
# HELIX_COST_LIMIT=50.00

# Dashboard port
# HELIX_DASHBOARD_PORT=3000

# Path to pre-built database
# HELIX_DB_PATH=/path/to/helix-unified.db
